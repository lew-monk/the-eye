{
  "extends": "../../tsconfig.json",
  "include": ["src/**/*"],
  "exclude": ["node_modules"],
  "compilerOptions": {
    "baseUrl": ".",
    "exactOptionalPropertyTypes": false,
    "paths": {
      "@/*": ["./src/*"],
      "@workspace/shared": ["../../packages/shared/src"],
      "@workspace/core": ["../../packages/core/src"],
      "@workspace/workers": ["../../packages/workers/src"],
      "drizzle-orm": ["../../packages/shared/node_modules/drizzle-orm"],
      "drizzle-orm/*": ["../../packages/shared/node_modules/drizzle-orm/*"]
    }
  }
}
