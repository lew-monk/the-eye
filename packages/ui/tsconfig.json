{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2022", "dom"],
    "moduleResolution": "node",
    "module": "commonjs",
    "baseUrl": ".",
    "noEmit": false,
    "declaration": true,
    "outDir": "./dist",
    "paths": {
      "@/*": ["./src/*"],
      "@workspace/ui": ["./src"],
      "@workspace/shared": ["../shared/src"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
