{
  "name": "@workspace/shared",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc --emitDeclarationOnly --skipLibCheck && bun build ./src/index.ts --outdir ./dist --target node",
    "dev": "tsc --emitDeclarationOnly --watch",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push:pg",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "bullmq": "^4.0.0",
    "date-fns": "^2.30.0",
    "drizzle-kit": "^0.31.8",
    "drizzle-orm": "^0.45.1",
    "ioredis": "^5.0.0",
    "postgres": "^3.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.6",
    "typescript": "^5.0.0"
  }
}
